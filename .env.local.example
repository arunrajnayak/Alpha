# =============================================
# Alpha Portfolio Tracker - Environment Variables
# =============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local

# ===========================================
# DATABASE (Required) - Turso
# ===========================================
# Sign up at https://turso.tech and create a database
# Then run:
#   turso db show <db-name> --url
#   turso db tokens create <db-name>
DATABASE_URL=libsql://your-database.turso.io?authToken=your-auth-token

# ===========================================
# UPSTOX API (Required)
# ===========================================
# Create an app at https://developer.upstox.com/
# Set redirect URL to: http://localhost:3000/api/upstox/callback (for local dev)
# For production, use: https://your-vercel-app.vercel.app/api/upstox/callback
UPSTOX_API_KEY=your-api-key
UPSTOX_API_SECRET=your-api-secret
UPSTOX_REDIRECT_URI=http://localhost:3000/api/upstox/callback
UPSTOX_MOBILE_NUMBER=your-mobile-number
UPSTOX_TOTP_SECRET=your-totp-secret
UPSTOX_PIN=your-pin

# ===========================================
# APP CONFIGURATION (Optional)
# ===========================================
# Display name shown in the UI (defaults to 'User')
# APP_USER_NAME=YourName
# NEXT_PUBLIC_APP_USER_NAME=YourName

# ===========================================
# CRON JOBS (Optional - for cron-job.org)
# ===========================================
# Secret to secure your cron endpoints
# CRON_SECRET=your-random-secret-string

# ===========================================
# ZERODHA KITE (Optional - for order sync)
# ===========================================
# Only needed if using the Zerodha order sync feature
# ZERODHA_USER_ID=your-user-id
# ZERODHA_PASSWORD=your-password
# ZERODHA_TOTP_SECRET=your-totp-secret
# ZERODHA_API_KEY=your-kite-api-key
# ZERODHA_API_SECRET=your-kite-api-secret

# ===========================================
# GITHUB ACTIONS (Optional - for automated order sync)
# ===========================================
# Required if you want to trigger Zerodha sync from the UI
# GITHUB_PAT=your-github-personal-access-token
