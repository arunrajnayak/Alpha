# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Editor-specific
.cursorrules

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
.env*.local
*.db
*.db-journal

# Data files and reports (generated output)
*.csv
*.xlsx
comparison_data.json
*_report.txt
discrepancies.csv
full_comparison_output.txt
nse_cache.json

# Database backups (may contain sensitive data)
backups/*.json
!backups/.gitkeep
*.backup_*

# Android build artifacts
android/app/build/
android/.gradle/
android/build/
*.apk
*.aab
